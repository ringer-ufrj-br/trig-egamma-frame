Bootstrap: docker
From: pytorch/pytorch:2.0.1-cuda11.7-cudnn8-devel


%environment
    export LC_ALL=en_US.utf-8
    export LANG=en_US.utf-8
    export SLANGUAGE en_US:en
    export TZ=America/New_York
    export DEBIAN_FRONTEND=noninteractive

%post
    apt-get update && apt-get install -y git && \
    apt-get install -y texlive-full 
    
    apt-get update && \
    apt-get install -y --no-install-recommends git wget unzip bzip2 build-essential ca-certificates && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

    mkdir -p /opt/etc

    && conda create -y -n dummy_env  \
    && echo -e "#! /bin/bash\n\n# script to activate the conda environment" > ~/.bashrc \
    && conda init bash \
    && echo -e "\nconda activate dummy_env" >> ~/.bashrc \
    && echo "echo \"MiniConda Setted!\"" >>  ~/.bashrc \
    && conda clean -a \
    && cp ~/.bashrc /opt/etc/bashrc
    
    unset DEBIAN_FRONTEND