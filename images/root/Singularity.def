Bootstrap: docker
From: rootproject/root:6.30.04-ubuntu22.04

%post
    export DEBIAN_FRONTEND=noninteractive
    
    # update all packages
    apt-get update -y --fix-missing

    # root dependencies
    apt-get install -y dpkg-dev cmake g++ gcc binutils libx11-dev libxpm-dev \
    libxft-dev libxext-dev python3 python3-pip libssl-dev libafterimage0

    # others
    apt-get install -y wget git gfortran libpcre3-dev \
    xlibmesa-glu-dev libglew-dev libftgl-dev \
    libmysqlclient-dev libfftw3-dev libcfitsio-dev \
    graphviz-dev libavahi-compat-libdnssd-dev \
    libldap2-dev python3-dev python3-numpy libxml2-dev libkrb5-dev \
    libgsl0-dev qtwebengine5-dev nlohmann-json3-dev

    pip install --upgrade pip
    pip install virtualenv

%runscript
    exec /bin/bash "$@"
